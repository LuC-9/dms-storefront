# Prisma SQLite connection string used by local development and Prisma CLI commands.
DATABASE_URL="file:./dev.db"

# NextAuth signing secret for JWT sessions and auth tokens.
NEXTAUTH_SECRET="replace-with-strong-secret"

# Public base URL used by NextAuth callbacks and reset-link generation.
NEXTAUTH_URL="http://localhost:3000"

# Optional provider override: use "simulator" for local test mode or "razorpay" for real gateway flows.
PAYMENT_PROVIDER="simulator"

# Razorpay test/public key id. Leave blank unless PAYMENT_PROVIDER is "razorpay" or auto-selection should prefer Razorpay.
RAZORPAY_KEY_ID=

# Razorpay test/secret key. Leave blank for simulator-only local development.
RAZORPAY_KEY_SECRET=

# Razorpay webhook signing secret used by /api/payments/webhook.
RAZORPAY_WEBHOOK_SECRET=

# Optional HMAC secret for the local simulator. When blank, the app derives one from NEXTAUTH_SECRET.
SIMULATOR_SECRET=

# Flat shipping charge stored in paise. Set to 0 for free shipping in local development.
SHIPPING_FLAT_PAISE=0
